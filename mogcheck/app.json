{
  "expo": {
    "name": "MogCheck",
    "slug": "mogcheck",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "mogcheck",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.mogcheck.app",
      "buildNumber": "1",
      "deploymentTarget": "16.0",
      "infoPlist": {
        "NSCameraUsageDescription": "MogCheck needs camera access to scan and analyze your facial proportions.",
        "NSPhotoLibraryUsageDescription": "MogCheck needs photo library access so you can upload existing photos for analysis.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "associatedDomains": []
    },
    "plugins": [
      "expo-router",
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "MogCheck needs camera access to scan and analyze your facial proportions.",
          "enableMicrophonePermission": false
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/BebasNeue-Regular.ttf",
            "./assets/fonts/PlusJakartaSans-Regular.ttf",
            "./assets/fonts/PlusJakartaSans-Medium.ttf",
            "./assets/fonts/PlusJakartaSans-SemiBold.ttf",
            "./assets/fonts/PlusJakartaSans-Bold.ttf"
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "YOUR_EAS_PROJECT_ID"
      }
    },
    "owner": "mogcheck"
  }
}
